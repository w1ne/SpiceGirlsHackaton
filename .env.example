# Copy to .env and fill in. .env is git-ignored — never commit real values.

# Supabase Personal Access Token (Management API / CLI auth)
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App credentials (after the Supabase project is provisioned)
SUPABASE_PROJECT_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# DeepInfra (phone app: STT / LLM / TTS)
DEEPINFRA_API_KEY=
