{
  "name": "spicegirls-app",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "sync": "vite build && cap sync",
    "test": "vitest run",
    "test:watch": "vitest",
    "apk": "vite build && cap sync android && (cd android && ./gradlew assembleDebug) && cp android/app/build/outputs/apk/debug/app-debug.apk ../SpiceGirls.apk && echo '\\n✅ Shareable APK at ./SpiceGirls.apk — contains only the public anon key, no provider keys'"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^6.0.1",
    "@capacitor-community/speech-recognition": "6.0.0",
    "@capacitor-community/text-to-speech": "6.1.0",
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@elevenlabs/client": "^1.9.0",
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
